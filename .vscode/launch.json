{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch CMake Target",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "TRACY_NO_INVARIANT_CHECK",
                    "value": "1"
                },
                {
                    "name": "ASCEND_PROCESS_LOG_PATH",
                    "value": "/tmp/ascend_log"
                }
            ],
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
