{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "environment": {
        "VSCMD_ARG_HOST_ARCH": "x64",
        "VSCMD_ARG_TGT_ARCH": "x64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "${sourceDir}/.cpm-cache",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TRACY_STATIC": "ON",
        "TRACY_ENABLE": "ON",
        "TRACY_NO_EXIT": "ON"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "${sourceDir}/.cpm-cache",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TRACY_STATIC": "ON",
        "TRACY_ENABLE": "ON",
        "TRACY_NO_EXIT": "ON",
        "LEGACY": "ON"
      }
    },
    {
      "name": "wsl2-base",
      "hidden": true,
      "inherits": "linux-base",
      "condition": {
        "type": "notEquals",
        "lhs": "$env{WSL_INTEROP}",
        "rhs": ""
      },
      "cacheVariables": {
        "TRACY_TIMER_FALLBACK": "ON",
        "TRACY_DISALLOW_HW_TIMER": "ON"
      }
    },
    {
      "name": "client-debug",
      "displayName": "[Win][Client] Debug",
      "description": "Build TracyClient instrumentation library (Debug)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/out/client-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TRACY_ENABLE": "ON"
      }
    },
    {
      "name": "client-release",
      "displayName": "[Win][Client] Release",
      "description": "Build TracyClient instrumentation library (Release)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/out/client-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TRACY_ENABLE": "ON"
      }
    },
    {
      "name": "all-debug",
      "displayName": "[Win][All] Debug  (Client + Capture + Test)",
      "description": "Build TracyClient, tracy-capture and tracy-test in one pass (Debug)",
      "inherits": "windows-base",
